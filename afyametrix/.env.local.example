
NEXT_PUBLIC_APP_NAME=AfyaMetrix
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Backend API base URL - Update this with your production API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_PHOTOS=true
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=false
NEXT_PUBLIC_ENABLE_HEATMAP=false
NEXT_PUBLIC_ENABLE_EXPORT=false
